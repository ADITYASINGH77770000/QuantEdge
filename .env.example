# QuantEdge Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# Gmail SMTP (for price alerts)
GMAIL_SENDER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password
GMAIL_RECEIVER=receiver@example.com

# NewsAPI (https://newsapi.org - free tier works)
NEWS_API_KEY=your_news_api_key

# Gemini AI (optional - for explainable summaries in the signals page)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Alpaca Markets (optional - for live trading module)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# App settings
DEMO_MODE=true
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
